{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AX Control",
  "version": "1.3.3",
  "identifier": "com.felipelima.axios16controller",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AX Control",
        "width": 1600,
        "height": 900,
        "minWidth": 1366,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "useHttpsScheme": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 20 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://axcontrol.com.br/api/app/updater.php?target={{target}}&arch={{arch}}&current_version={{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUxQzQ4MUE2QkFFMDlCQjEKUldTeG0rQzZwb0hFVVNqank4UG5UZFNjd29vc2Q5aXVrWEZ4eFc3bnZHUDhGMHpmU0JOMTI3OFkK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "infoPlist": "Info.plist",
      "signingIdentity": "Developer ID Application: Felipe Rocha Lima (UQ34KWR782)"
    },
    "iOS": {
      "infoPlist": "Info.ios.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
